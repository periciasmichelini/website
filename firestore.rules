rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /metadata/{document} {
      allow read, write: if true;
    }
    match /suggestions/{document} {
      allow read, write: if true;
    }
    match /articles/{document} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}